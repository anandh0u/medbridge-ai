# Azure AI Foundry project endpoint.
# Format: https://<foundry-resource>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/api/projects/your-project

# Foundry model deployment used by the MedBridge AI agent.
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Optional custom Foundry agent name for deployment scripts.
MEDBRIDGE_AGENT_NAME=medbridge-ai

# Keep local demos deterministic unless you intentionally want Foundry IQ calls.
MEDBRIDGE_USE_LIVE_FOUNDRY=false

# Optional Azure tenant/client settings if DefaultAzureCredential needs them.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
